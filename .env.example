PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (use Atlas for production)
MONGODB_URI=mongodb://localhost:27017/appointment-saas

# JWT - use a long random string in production
JWT_SECRET=your_jwt_secret_key_here_minimum_32_chars
JWT_EXPIRE=7d

# Frontend URL for CORS (set to your deployed frontend URL in production)
FRONTEND_URL=http://localhost:3000

# Email (use Gmail App Password or SendGrid in production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Optional: Telegram bot for notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional: Twilio for SMS/WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Optional: Groq for AI receptionist (using llama-3.3-70b-versatile)
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key
